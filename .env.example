# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, never exposed to the client. Used for webhook/admin writes.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public base URL of the deployed app (used for OAuth redirects and Stripe success/cancel URLs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Encryption ---
# 32-byte (256-bit) key, base64-encoded, used for AES-256-GCM encryption of user LLM API keys.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Brave Search (server-owned infra key, NOT a per-user LLM credential) ---
BRAVE_SEARCH_API_KEY=xxxxxxxxxxxxxxxx

# --- Stripe (TEST MODE keys only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
# Price is created programmatically per checkout session ($5 one-time), no Price ID needed.

# NOTE: There is intentionally NO OpenAI/Anthropic/Kimi API key here.
# Those are supplied per-user via the Settings page and stored encrypted in Postgres.
# The app must remain unable to make chat completions until a user adds their own key.
